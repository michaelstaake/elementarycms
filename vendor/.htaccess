# Deny access to PHP files for security
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Deny access to config files
<FilesMatch "\.(json|yml|yaml|xml|ini|lock)$">
    Require all denied
</FilesMatch>

# Allow access to static assets (CSS, JS, fonts, images)
<FilesMatch "\.(css|js|map|woff|woff2|ttf|eot|svg|png|jpg|jpeg|gif|ico|scss)$">
    Require all granted
</FilesMatch>
